struct StackPertandingan {
    LinkedListPertandingan list;
};

void initStack(StackPertandingan* s) {
    initListPertandingan(&s->list);
}

void pushStack(StackPertandingan* s, Pertandingan* val) {
    NodePertandingan* newNode = new NodePertandingan;
    newNode->data = val;
    newNode->next = s->list.kepala;
    s->list.kepala = newNode;
    s->list.ukuran++;
}

Pertandingan* popStack(StackPertandingan* s) {
    if (!s->list.kepala) return nullptr;
    NodePertandingan* temp = s->list.kepala;
    Pertandingan* val = temp->data;
    s->list.kepala = s->list.kepala->next;
    delete temp;
    s->list.ukuran--;
    return val;
}

int stackKosong(StackPertandingan* s) {
    return s->list.ukuran == 0;
}

