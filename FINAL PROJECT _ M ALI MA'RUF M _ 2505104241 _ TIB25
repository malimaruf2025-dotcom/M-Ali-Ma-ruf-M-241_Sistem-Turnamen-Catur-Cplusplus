Pertandingan* dequeue(QueuePertandingan* q) {
    if (!q->list.kepala) return nullptr;
    NodePertandingan* temp = q->list.kepala;
    Pertandingan* val = temp->data;
    q->list.kepala = q->list.kepala->next;
    delete temp;
    q->list.ukuran--;
    return val;
}

int queueKosong(QueuePertandingan* q) {
    return q->list.ukuran == 0;
}

