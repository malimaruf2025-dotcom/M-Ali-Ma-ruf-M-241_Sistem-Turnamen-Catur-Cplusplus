const int UKURAN_HASH = 101;

struct HashNode {
    int kunci;
    Pemain* nilai;
    HashNode* next;
};

struct LinkedListHash {
    HashNode* kepala;
};

void initListHash(LinkedListHash* list) {
    list->kepala = nullptr;
}

void tambahHash(LinkedListHash* list, int kunci, Pemain* pemain) {
    HashNode* newNode = new HashNode;
    newNode->kunci = kunci;
    newNode->nilai = pemain;
    newNode->next = list->kepala;
    list->kepala = newNode;
}

Pemain* cariHash(LinkedListHash* list, int kunci) {
    HashNode* cur = list->kepala;
    while (cur) {
        if (cur->kunci == kunci) return cur->nilai;
        cur = cur->next;
    }
    return nullptr;
}

bool hapusHash(LinkedListHash* list, int kunci) {
    HashNode* prev = nullptr;
    HashNode* cur = list->kepala;
    while (cur) {
        if (cur->kunci == kunci) {
            if (prev) prev->next = cur->next;
            else list->kepala = cur->next;
            delete cur;
            return true;
        }
        prev = cur;
        cur = cur->next;
    }
    return false;
}

struct HashTable {
    LinkedListHash tabel[UKURAN_HASH];
};

void initHashTable(HashTable* ht) {
    for (int i = 0; i < UKURAN_HASH; i++) {
        initListHash(&ht->tabel[i]);
    }
}

int hashing(int kunci) {
    return kunci % UKURAN_HASH;
}

void hashSisip(HashTable* ht, int kunci, Pemain* pemain) {
    int idx = hashing(kunci);
    tambahHash(&ht->tabel[idx], kunci, pemain);
}

Pemain* hashCari(HashTable* ht, int kunci) {
    int idx = hashing(kunci);
    return cariHash(&ht->tabel[idx], kunci);
}

void hashHapus(HashTable* ht, int kunci) {
    int idx = hashing(kunci);
    hapusHash(&ht->tabel[idx], kunci);
}

struct BSTNode {
    Pemain* data;
    BSTNode* kiri;
    BSTNode* kanan;
};

BSTNode* buatBSTNode(Pemain* p) {
    BSTNode* node = new BSTNode;
    node->data = p;
    node->kiri = nullptr;
    node->kanan = nullptr;
    return node;
}

BSTNode* bstSisipRekursif(BSTNode* node, Pemain* p) {
    if (!node) return buatBSTNode(p);
    if (p->rating < node->data->rating)
        node->kiri = bstSisipRekursif(node->kiri, p);
    else
        node->kanan = bstSisipRekursif(node->kanan, p);
    return node;
}

void bstInorderRekursif(BSTNode* node, void (*kunjungi)(Pemain*)) {
    if (!node) return;
    bstInorderRekursif(node->kiri, kunjungi);
    kunjungi(node->data);
    bstInorderRekursif(node->kanan, kunjungi);
}

Pemain* bstCariRekursif(BSTNode* node, int rating) {
    if (!node) return nullptr;
    if (rating == node->data->rating) return node->data;
    else if (rating < node->data->rating) return bstCariRekursif(node->kiri, rating);
    else return bstCariRekursif(node->kanan, rating);
}

int bstKedalamanMaksRekursif(BSTNode* node) {
    if (!node) return 0;
    int kiri = bstKedalamanMaksRekursif(node->kiri);
    int kanan = bstKedalamanMaksRekursif(node->kanan);
    return (kiri > kanan ? kiri : kanan) + 1;
}

