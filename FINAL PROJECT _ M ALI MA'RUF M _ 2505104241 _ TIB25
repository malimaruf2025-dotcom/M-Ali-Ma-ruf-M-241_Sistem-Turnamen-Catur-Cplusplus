    cin >> ptg->idPemain1;
    cout << "Masukkan ID Pemain 2: ";
    cin >> ptg->idPemain2;
    
    Pemain* p1 = hashCari(&hashTabelPemain, ptg->idPemain1);
    Pemain* p2 = hashCari(&hashTabelPemain, ptg->idPemain2);
    if (!p1 || !p2) {
        cout << "ID pemain tidak valid.\n";
        delete ptg;
        nextIdPertandingan--;
        return;
    }
    if (p1->idKlub == p2->idKlub) {
        cout << "Pemain harus dari klub berbeda.\n";
        delete ptg;
        nextIdPertandingan--;
        return;
    }
    ptg->idKlub1 = p1->idKlub;
    ptg->idKlub2 = p2->idKlub;
    ptg->hasil = 0;
    tambahPertandinganBelakang(&daftarPertandingan, ptg);
    enqueue(&antrianPertandingan, ptg);
    cout << "Jadwal berhasil dibuat. ID Pertandingan: " << ptg->id << endl;
}

void lihatJadwal() {
    if (daftarPertandingan.ukuran == 0) {
        cout << "Belum ada jadwal.\n";
        return;
    }
    cout << "\n===== JADWAL PERTANDINGAN =====\n";
    NodePertandingan* cur = daftarPertandingan.kepala;
    while (cur) {
        cetakPertandingan(cur->data);
        cur = cur->next;
    }
}

void hapusJadwal() {
    lihatJadwal();
    if (daftarPertandingan.ukuran == 0) return;
    int id;
    cout << "ID pertandingan yang akan dihapus: ";
    cin >> id;
    hapusPertandinganById(&daftarPertandingan, id);
    cout << "Jadwal berhasil dihapus.\n";
}

void inputHasil() {
    if (queueKosong(&antrianPertandingan)) {
        cout << "Tidak ada pertandingan dalam antrian.\n";
        return;
    }
    Pertandingan* m = dequeue(&antrianPertandingan);
    cout << "Memainkan pertandingan ID " << m->id << " : " << m->idPemain1 << " vs " << m->idPemain2 << endl;
    cout << "Hasil (1: P1 menang, 2: P2 menang, 3: Seri): ";
    int res;
    cin >> res;
    if (res < 1 || res > 3) {
        cout << "Hasil tidak valid. Pertandingan dikembalikan ke antrian.\n";
        enqueue(&antrianPertandingan, m);
        return;
    }
    m->hasil = res;
    Pemain* p1 = hashCari(&hashTabelPemain, m->idPemain1);
    Pemain* p2 = hashCari(&hashTabelPemain, m->idPemain2);
    if (res == 1) p1->skor += 1;
    else if (res == 2) p2->skor += 1;
    else { p1->skor += 1; p2->skor += 1; }
    perbaruiTotalPoinKlub(p1->idKlub);
    perbaruiTotalPoinKlub(p2->idKlub);
    graphTambahSisi(&graphKlub, p1->idKlub, p2->idKlub);
    pushStack(&riwayatPertandingan, m);
    cout << "Hasil pertandingan dicatat.\n";
}

void lihatHasil() {
    if (daftarPertandingan.ukuran == 0) {
        cout << "Belum ada pertandingan.\n";
        return;
    }
    cout << "\n===== HASIL PERTANDINGAN =====\n";
    NodePertandingan* cur = daftarPertandingan.kepala;
    while (cur) {
        if (cur->data->hasil != 0)
            cetakPertandingan(cur->data);
        cur = cur->next;
    }
}

void undoHasil() {
    if (stackKosong(&riwayatPertandingan)) {
        cout << "Tidak ada riwayat.\n";
        return;
    }
    Pertandingan* m = popStack(&riwayatPertandingan);
    Pemain* p1 = hashCari(&hashTabelPemain, m->idPemain1);
    Pemain* p2 = hashCari(&hashTabelPemain, m->idPemain2);
    if (m->hasil == 1) p1->skor -= 1;
    else if (m->hasil == 2) p2->skor -= 1;
    else if (m->hasil == 3) { p1->skor -= 1; p2->skor -= 1; }
    perbaruiTotalPoinKlub(p1->idKlub);
    perbaruiTotalPoinKlub(p2->idKlub);
    m->hasil = 0;
    enqueue(&antrianPertandingan, m);
    cout << "Hasil di-undo.\n";
}

void rankingPemain() {
    if (daftarPemain.ukuran == 0) {
        cout << "Tidak ada pemain.\n";
        return;
    }
    Pemain** arr = new Pemain*[daftarPemain.ukuran];
    int idx = 0;
    NodePemain* cur = daftarPemain.kepala;
    while (cur) {
        arr[idx++] = cur->data;
        cur = cur->next;
    }
    quickSortPemain(arr, 0, daftarPemain.ukuran-1);
    cout << "\n===== RANKING PEMAIN (berdasarkan skor) =====\n";
    for (int i = 0; i < daftarPemain.ukuran; i++) {
        cout << (i+1) << ". ";
        cetakPemain(arr[i]);
    }
    delete[] arr;
}

void statistikTurnamen() {
    cout << "\n===== STATISTIK TURNAMEN =====\n";
    cout << "Total Klub: " << daftarKlub.ukuran << endl;
    cout << "Total Pemain: " << daftarPemain.ukuran << endl;
    int selesai = 0;
    NodePertandingan* cur = daftarPertandingan.kepala;
    while (cur) {
        if (cur->data->hasil != 0) selesai++;
        cur = cur->next;
    }
    cout << "Pertandingan selesai: " << selesai << endl;
    cout << "Antrian pertandingan: " << getUkuranQueue(&antrianPertandingan) << endl;
    if (daftarPemain.ukuran > 0) {
        int totalRating = 0;
        NodePemain* curP = daftarPemain.kepala;
        while (curP) {
            totalRating += curP->data->rating;
            curP = curP->next;
        }
        double rata = (double)totalRating / daftarPemain.ukuran;
        cout << "Rata-rata rating pemain: " << rata << endl;
    }
    cout << "Kedalaman BST (rekursif): " << bstKedalamanMaksRekursif(bstAkar) << endl;
    cout << "\nKomponen terhubung antar klub (Graph):\n";
    graphKomponenTerhubung(&graphKlub, cetakNamaKlub);
}

void lihatPeserta() {
    cout << "\n===== DAFTAR PESERTA TURNAMEN =====\n";
    if (daftarPemain.ukuran == 0) {
        cout << "Belum ada peserta.\n";
        return;
    }
    NodePemain* cur = daftarPemain.kepala;
    while (cur) {
        cout << "ID: " << cur->data->id << ", Nama: " << cur->data->nama << ", Klub: ";
        Klub* k = nullptr;
        NodeKlub* curK = daftarKlub.kepala;
        while (curK) {
            if (curK->data->id == cur->data->idKlub) { k = curK->data; break; }
            curK = curK->next;
        }
        if (k) cout << k->nama;
        else cout << "Unknown";
        cout << ", Rating: " << cur->data->rating << endl;
        cur = cur->next;
    }
}

