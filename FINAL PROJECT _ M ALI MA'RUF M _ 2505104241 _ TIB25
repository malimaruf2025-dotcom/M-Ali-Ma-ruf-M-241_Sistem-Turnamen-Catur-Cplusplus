void hapusPemainById(LinkedListPemain* list, int id) {
    NodePemain* prev = nullptr;
    NodePemain* cur = list->kepala;
    while (cur) {
        if (cur->data->id == id) {
            if (prev) prev->next = cur->next;
            else list->kepala = cur->next;
            delete cur->data;
            delete cur;
            list->ukuran--;
            return;
