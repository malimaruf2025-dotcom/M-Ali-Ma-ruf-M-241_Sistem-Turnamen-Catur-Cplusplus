void graphDfsRekursif(Graph* g, int v, bool dikunjungi[], void (*kunjungi)(int)) {
    dikunjungi[v] = true;
    kunjungi(v);
    NodeInt* cur = g->adj[v].kepala;
    while (cur) {
        if (!dikunjungi[cur->data])
            graphDfsRekursif(g, cur->data, dikunjungi, kunjungi);
        cur = cur->next;
    }
}

