void tukarPemain(Pemain** a, Pemain** b) {
    Pemain* temp = *a;
    *a = *b;
    *b = temp;
}

int partisiPemain(Pemain** arr, int rendah, int tinggi) {
    int pivot = arr[tinggi]->skor;
    int i = rendah - 1;
    for (int j = rendah; j < tinggi; j++) {
        if (arr[j]->skor >= pivot) {
            i++;
            tukarPemain(&arr[i], &arr[j]);
        }
    }
    tukarPemain(&arr[i+1], &arr[tinggi]);
    return i+1;
}

void quickSortPemain(Pemain** arr, int rendah, int tinggi) {
    if (rendah < tinggi) {
        int pi = partisiPemain(arr, rendah, tinggi);
        quickSortPemain(arr, rendah, pi-1);
        quickSortPemain(arr, pi+1, tinggi);
    }
}

int binarySearchPemain(Pemain** arr, int n, int targetRating) {
    int kiri = 0, kanan = n-1;
    while (kiri <= kanan) {
        int tengah = kiri + (kanan - kiri)/2;
        if (arr[tengah]->rating == targetRating) return tengah;
        else if (arr[tengah]->rating < targetRating) kiri = tengah+1;
        else kanan = tengah-1;
    }
    return -1;
}

